APP_NAME="identity-api"
NODE_ENV="development"
PORT="3000"
API_PREFIX="api"
TRUST_PROXY="false"
APP_TIME_ZONE="America/Bogota"

CORS_ORIGINS="http://localhost:3000,http://localhost:5173"
CORS_CREDENTIALS="true"
CORS_METHODS="GET,HEAD,POST,PUT,PATCH,DELETE,OPTIONS"
CORS_ALLOWED_HEADERS="Authorization,Content-Type,X-Request-Id"
CORS_EXPOSED_HEADERS="X-Request-Id,X-Response-Time"

LOG_LEVEL="debug"
LOG_PRETTY_PRINT="true"

DATABASE_URL="postgresql://postgres:password@localhost:5432/identity_api?schema=public"
AUTH_ACCESS_TOKEN_SECRET="identity-access-secret-change-me"
AUTH_ACCESS_TOKEN_TTL="15m"
AUTH_REFRESH_TOKEN_SECRET="identity-refresh-secret-change-me"
AUTH_REFRESH_TOKEN_TTL="30d"
AUTH_BCRYPT_SALT_ROUNDS="12"
AUTH_PASSWORD_RECOVERY_CODE_TTL_MINUTES="10"
AUTH_PASSWORD_RECOVERY_MAX_ATTEMPTS="5"
AUTH_PASSWORD_RECOVERY_LOG_CODE_IN_DEV="true"
AUTH_SOCIAL_GOOGLE_CLIENT_IDS="google-client-id.apps.googleusercontent.com"
AUTH_SOCIAL_FACEBOOK_APP_ID="123456789012345"
AUTH_SOCIAL_FACEBOOK_APP_SECRET="change-me"
AUTH_SOCIAL_FACEBOOK_GRAPH_VERSION="v23.0"
EMAIL_ENABLED="false"
EMAIL_SMTP_HOST="smtp.example.com"
EMAIL_SMTP_PORT="465"
EMAIL_SMTP_SECURE="true"
EMAIL_SMTP_USER="no-reply@example.com"
EMAIL_SMTP_PASSWORD="change-me"
EMAIL_FROM_NAME="Identity API"
EMAIL_FROM_ADDRESS="no-reply@example.com"
REDIS_URL="redis://localhost:6379"
STORAGE_S3_ENDPOINT="http://localhost:9000"
STORAGE_S3_ACCESS_KEY="admin"
STORAGE_S3_SECRET_KEY="admin123"
STORAGE_S3_BUCKET="avatars"
STORAGE_S3_FORCE_PATH_STYLE="true"
STORAGE_S3_PUBLIC_BASE_URL="http://localhost:9000"
STORAGE_MAX_UPLOAD_SIZE="5242880"
QUEUE_PREFIX="identity-api"
FACIAL_VALIDATOR_BASE_URL="http://localhost:8000"

RATE_LIMIT_TTL="60000"
RATE_LIMIT_LIMIT="100"
SENSITIVE_RATE_LIMIT_TTL="60000"
SENSITIVE_RATE_LIMIT_LIMIT="120"
AVATAR_RATE_LIMIT_TTL="60000"
AVATAR_RATE_LIMIT_LIMIT="30"
